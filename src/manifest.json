{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "10.0.2",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "alarms",
    "idle",
    "notifications",
    "declarativeNetRequest",
    "scripting",
    "favicon"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "options_page": "dashboard/index.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "*://*.chrome.google.com/*"
      ],
      "js": [
        "content/site-tracker.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "blocked/index.html",
        "_favicon/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}